# 신청 목록 저장 데이터베이스 경로 (기본값: pending.db)
DB_PATH=pending.db

# 관리자 페이지 접속 비밀번호 (필수, 둘 중 하나만 설정)
# ADMIN_PASSWORD: 평문 비밀번호 (서버 시작 시 자동으로 해싱됨)
ADMIN_PASSWORD=your_admin_password_here
# ADMIN_PASSWORD_HASH: 직접 생성한 해시값 (우선 적용)
# python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_password'))"
# ADMIN_PASSWORD_HASH=

# Flask 세션 암호화 키 (필수, 임의의 긴 문자열 권장)
# python3 -c "import secrets; print(secrets.token_hex(32))" 로 생성 가능
SECRET_KEY=your_secret_key_here

# 세션 타임아웃 (분 단위, 기본값: 60)
SESSION_TIMEOUT_MINUTES=60

# Cloudflare Turnstile 키 (선택, 미입력시 Turnstile 미사용)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 마스토돈 서버 도메인 (기본값: occm.cc)
MASTODON_DOMAIN=occm.cc

# 서버 표시 이름 (기본값: 자커마스)
SERVER_NAME_KO=자커마스

# Redis 연결 URL (rate limiting용, 예: redis://:password@localhost:6379)
REDIS_URL=redis://localhost:6379
