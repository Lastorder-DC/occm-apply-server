# 신청 목록 저장 파일 경로 (기본값: pending.txt)
FILE_PATH=pending.txt

# 관리자 페이지 접속 비밀번호 (필수)
ADMIN_PASSWORD=your_admin_password_here

# Flask 세션 암호화 키 (필수, 임의의 긴 문자열 권장)
SECRET_KEY=your_secret_key_here

# Cloudflare Turnstile 키 (선택, 미입력시 Turnstile 미사용)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 마스토돈 서버 도메인 (기본값: occm.cc)
MASTODON_DOMAIN=occm.cc

# 서버 표시 이름 (기본값: 자커마스)
SERVER_NAME_KO=자커마스

# Redis 연결 URL (rate limiting용, 예: redis://:password@localhost:6379)
REDIS_URL=redis://localhost:6379
